APP_ENV=local
APP_DEBUG=true
SESSION_SECURE=false

# Local: https://shop.roselira.local | Production: https://roselira.shop
APP_URL=

# Analytics (loaded after cookie consent)
META_PIXEL_ID=
GA4_MEASUREMENT_ID=
GTM_CONTAINER_ID=

# Product feeds: /feeds/meta.xml?token=...& /feeds/google.xml?token=...
FEED_SECRET=

# Footer contact
CONTACT_EMAIL=
CONTACT_TELEGRAM=

# Git auto-update (admin /admin/system + cron.php)
GIT_REPO_URL=https://github.com/iteffa-works/roselira.shop.git
GIT_BRANCH=main
# Path to git binary if not in PHP PATH (e.g. /usr/bin/git or C:\OSPanel\modules\Git\bin\git.exe)
GIT_BINARY=
CRON_SECRET=

# Google reCAPTCHA v2 (https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
