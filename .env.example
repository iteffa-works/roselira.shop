APP_ENV=local
APP_DEBUG=true
SESSION_SECURE=false

# Local: https://shop.roselira.local | Production: https://roselira.shop
APP_URL=

# Analytics (loaded after cookie consent)
META_PIXEL_ID=[ТУТ ID Meta Pixel з Events Manager, напр. 1234567890123456]
GA4_MEASUREMENT_ID=[ТУТ ID Google Analytics 4, напр. G-XXXXXXXXXX]
GTM_CONTAINER_ID=[ТУТ ID Google Tag Manager, напр. GTM-XXXXXXX]

# Google Analytics у Dashboard (вкладка Google): Looker embed АБО GA4 Data API
GA4_PROPERTY_ID=[ТУТ числовий Property ID з GA4 Admin → Property settings]
GA4_SERVICE_ACCOUNT_JSON=[ТУТ шлях до JSON service account, напр. storage/ga4-service-account.json]
GA4_LOOKER_EMBED_URL=[ТУТ embed URL звіту Looker Studio, якщо є]

# Product feeds: /feeds/meta.xml?token=...& /feeds/google.xml?token=...
FEED_SECRET=[ТУТ випадковий секрет для захисту product feeds ?token=]

# Footer contact (shown in site footer)
CONTACT_EMAIL=contact@roselira.shop
CONTACT_PHONE=+380966349498
CONTACT_TELEGRAM=
CONTACT_TELEGRAM_URL=https://t.me/kikomilanooooo

# Git auto-update (admin /admin/system + cron.php)
GIT_REPO_URL=https://github.com/iteffa-works/roselira.shop.git
GIT_BRANCH=main
GIT_BINARY=[ТУТ шлях до git, якщо не в PATH — /usr/bin/git або C:\OSPanel\modules\Git\bin\git.exe]
CRON_SECRET=[ТУТ секрет для HTTP-виклику cron.php ?token=]

# Google reCAPTCHA v2 (https://www.google.com/recaptcha/admin)
RECAPTCHA_SITE_KEY=[ТУТ Site Key з Google reCAPTCHA Admin]
RECAPTCHA_SECRET_KEY=[ТУТ Secret Key з Google reCAPTCHA Admin]
